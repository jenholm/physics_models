\@writefile{lot}{\contentsline {table}{\numberline {VI}{\ignorespaces Ell sensitivity: ISR (Gaussian kernel) stability metrics across kernel scale $\ell $ (non-degenerate regime, $\ell \ge 0.48$). The physically meaningful regime begins at $\ell \approx 0.5$, where $N_{\rm  eff}$ exceeds $\sim 30\%$ of $N$. Small-$\ell $ and boundary values are diagnostic artifacts reported in Appendix~\ref {app:degenerate}. The baseline global-census KL is $3.58\times 10^{-4}$.}}{8}{table.caption.57}\protected@file@percent }
\newlabel{tab:ell_sensitivity}{{VI}{8}{Ell sensitivity: ISR (Gaussian kernel) stability metrics across kernel scale $\ell $ (non-degenerate regime, $\ell \ge 0.48$). The physically meaningful regime begins at $\ell \approx 0.5$, where $N_{\rm eff}$ exceeds $\sim 30\%$ of $N$. Small-$\ell $ and boundary values are diagnostic artifacts reported in Appendix~\ref {app:degenerate}. The baseline global-census KL is $3.58\times 10^{-4}$}{table.caption.57}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces KL drift and Wasserstein distance vs.\ kernel scale $\ell $. The black dotted line is the global-census baseline; the gray dashed line is the shuffled null control.}}{8}{figure.caption.58}\protected@file@percent }
\newlabel{fig:ell_sensitivity_kl}{{7}{8}{KL drift and Wasserstein distance vs.\ kernel scale $\ell $. The black dotted line is the global-census baseline; the gray dashed line is the shuffled null control}{figure.caption.58}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Effective sample size $N_{\rm  eff}$ and basin exception rate vs.\ $\ell $. The sweet spot lies where $N_{\rm  eff}$ is large enough for statistical power but basin exceptions remain below 30\%.}}{8}{figure.caption.59}\protected@file@percent }
\newlabel{fig:ell_sensitivity_neff}{{8}{8}{Effective sample size $N_{\rm eff}$ and basin exception rate vs.\ $\ell $. The sweet spot lies where $N_{\rm eff}$ is large enough for statistical power but basin exceptions remain below 30\%}{figure.caption.59}{}}
