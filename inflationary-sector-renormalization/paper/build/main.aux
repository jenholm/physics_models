\newlabel{tab:degenerate_ell_sensitivity}{{XI}{13}{Degenerate and boundary rows from the ell sensitivity scan (Gaussian kernel). Rows with $\ell \lesssim 0.25$ are degenerate: $N_{\rm eff} \ll N$, producing trivially vanishing KL drift. The $\ell = 0.23$ row ($N_{\rm eff}/N = 0.25$) is a boundary case that narrowly fails the $N_{\rm eff}/N \ge 0.3$ threshold}{table.caption.84}{}}
\@writefile{lot}{\contentsline {table}{\numberline {XII}{\ignorespaces Full sigma--ell boundary grid including degenerate small-$\ell $ columns. Values at $\ell =0.10$ and $\ell =0.25$ are diagnostic artifacts: the narrow kernel forces $N_{\rm  eff} \ll N$, producing trivially large improvement ratios.}}{13}{table.caption.85}\protected@file@percent }
\newlabel{tab:degenerate_sigma_ell}{{XII}{13}{Full sigma--ell boundary grid including degenerate small-$\ell $ columns. Values at $\ell =0.10$ and $\ell =0.25$ are diagnostic artifacts: the narrow kernel forces $N_{\rm eff} \ll N$, producing trivially large improvement ratios}{table.caption.85}{}}
